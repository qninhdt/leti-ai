# ── Required for real model traffic ───────────────────────────────
# Your model API key (OpenAI-compatible; e.g. OpenRouter or any gateway).
# Required for the default (real-LLM) launch.
# Not needed for `./openlet-ai --mock` (network-free in-process backend).
OPENAI_API_KEY=sk-REPLACE_ME

# ── Model backend ─────────────────────────────────────────────────
# Unset = OpenRouter (https://openrouter.ai/api/v1).
# For the in-process mock LLM, `./openlet-ai --mock` sets this for you
# (to the mock's printed base_url VERBATIM — it already ends in /v1).
# Point it at any OpenAI-compatible gateway to self-host.
# OPENAI_API_BASE_URL=http://127.0.0.1:PORT/v1
OPENLET_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────
OPENLET_BIND=127.0.0.1:8787
OPENLET_DATA_DIR=~/.openlet
OPENLET_WORKSPACE=~/.openlet/workspace
OPENLET_LOG_FORMAT=pretty
RUST_LOG=info

# ── TUI ───────────────────────────────────────────────────────────
OPENLET_BASE_URL=http://127.0.0.1:8787

# ── Deployment profile + observability (Phase 6 / 10) ─────────────
# local | cloud. `cloud` requires a real Authenticator (fail-closed);
# `./openlet-ai` and the default Compose run as `local`.
OPENLET_RUNTIME_PROFILE=local
# Unset = metrics off (no Prometheus needed to run locally). Set to serve
# Prometheus text at GET /metrics on that bind (separate from the API).
# OPENLET_METRICS_BIND=0.0.0.0:9464

# ── Docker Compose host-port remap (local override only) ──────────
# The container always binds 8787 internally; these remap the HOST side
# so multiple projects can coexist. Used by docker-compose.override.yml.
OPENLET_HOST_PORT=18787
OPENLET_METRICS_HOST_PORT=19464

# ── Env separation ────────────────────────────────────────────────
# Copy this file per environment and select with --env-file:
#   .env.local / .env.dev / .env.staging / .env.prod  (all gitignored)
#   docker compose --env-file .env.local up
# Vars that typically differ per env: OPENLET_BIND, OPENLET_DATA_DIR,
# OPENAI_API_BASE_URL, OPENLET_LOG_FORMAT, OPENLET_METRICS_BIND,
# OPENLET_RUNTIME_PROFILE.
