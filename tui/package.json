{
  "name": "openlet",
  "version": "0.1.0",
  "description": "Openlet TUI client (Ink/React) for openlet-agent-core",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "openlet": "dist/cli.mjs"
  },
  "scripts": {
    "codegen": "openapi-typescript http://localhost:8787/v1/doc/openapi.json -o src/api/schema.d.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "diff": "^7.0.0",
    "eventsource": "^3.0.2",
    "eventsource-parser": "^3.0.0",
    "ink": "^5.2.0",
    "marked": "^14.1.3",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "ink-testing-library": "^4.0.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist"
  ]
}
