{
  "name": "openlet",
  "version": "0.1.0",
  "description": "Openlet TUI client (SolidJS/@opentui) for openlet-agent-core",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "bin": {
    "openlet": "dist/cli.mjs"
  },
  "scripts": {
    "codegen": "openapi-typescript http://localhost:8787/v1/doc/openapi.json -o src/api/schema.d.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/e2e/tui-real-binary-e2e.test.tsx",
    "test:watch": "vitest",
    "test:e2e:real": "OPENLET_TUI_REAL_E2E=1 vitest run tests/e2e/tui-real-binary-e2e.test.tsx",
    "test:e2e:real:openrouter": "OPENLET_TUI_REAL_E2E=1 OPENLET_LIVE_E2E=1 vitest run tests/e2e/tui-real-binary-e2e.test.tsx",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/keymap": "^0.4.1",
    "@opentui/solid": "^0.4.1",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "eventsource": "^4.1.0",
    "eventsource-parser": "^3.1.0",
    "marked": "^18.0.5",
    "openapi-fetch": "^0.17.0",
    "opentui-spinner": "^0.0.7",
    "solid-js": "^1.9.12",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.3",
    "babel-preset-solid": "^1.9.12",
    "esbuild-plugin-solid": "^0.6.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ]
}
