{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": [
    "src/components/markdown-renderer.tsx",
    "src/components/message-list.tsx",
    "src/components/status-bar.tsx",
    "src/components/tool-call-card.tsx",
    "src/views/agent-picker.tsx",
    "src/views/chat-view.tsx",
    "src/views/help-view.tsx",
    "src/views/permission-modal.tsx",
    "src/views/plugins-view.tsx",
    "src/views/session-picker.tsx"
  ]
}
